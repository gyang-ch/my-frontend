{"@context": "http://iiif.io/api/presentation/2/context.json", "@id": "https://www.loc.gov/item/2021666122/manifest.json", "@type": "sc:Manifest", "attribution": "Provided by the Library of Congress", "description": "This pictorial book from 1854 is known as one of the best books on morning glories published in Japan. It reflects the morning glory mania that began in 1847 and that was widespread among the people of Edo (present-day Tokyo) at that time. The book features colored prints of 36 morning glory flowers and leaves with strange shapes, by Hattori Sessai (1807-?), a Japanese painter known for his naturalist works. The descriptions were written by Bankaen Shujin, also known as Yokoyama Masana (1833-1908), who was a retainer of a Tokugawa shogun.", "label": "Morning Glory Flowers.", "logo": "https://loc.gov/static/images/logo-loc-new-branding.svg", "metadata": [{"label": "APA Citation Style", "value": "Hattori, S. &amp; Yokoyama, M. (1854) <cite>Morning Glory Flowers</cite>. [Pdf] Retrieved from the Library of Congress, https://www.loc.gov/item/2021666122/."}, {"label": "MLA Citation Style", "value": "Hattori, Sessai, Born 1807 Artist, and Masana Yokoyama. <cite>Morning Glory Flowers</cite>. 1854. Pdf. Retrieved from the Library of Congress, &lt;www.loc.gov/item/2021666122/&gt;."}, {"label": "Chicago Citation Style", "value": "Hattori, Sessai, Born 1807 Artist, and Masana Yokoyama. <cite>Morning Glory Flowers</cite>. 1854. Pdf. https://www.loc.gov/item/2021666122/."}, {"label": "Contributors", "value": ["Hattori, Sessai, born 1807 Artist.", "Yokoyama, Masana, 1833-1908 Author."]}, {"label": "Created Published", "value": ["1854."]}, {"label": "Original Format", "value": ["book"]}, {"label": "Subjects", "value": ["tokyo", "1800 to 1899", "japan", "edo", "flowers", "picture books"]}, {"label": "Online Format", "value": ["compressed data", "pdf", "image"]}, {"label": "Item Url", "value": "https://www.loc.gov/item/2021666122/"}], "navDate": "1854-01-01T00:00:00Z", "