{"@context": "http://iiif.io/api/presentation/2/context.json", "@id": "https://www.loc.gov/item/2021666418/manifest.json", "@type": "sc:Manifest", "attribution": "Provided by the Library of Congress", "description": "Ehon mushi-erami (The insect book) is by the ukiyo-e painter Kitagawa Utamaro (circa 1753-1806). It was created by him before he produced the bijin-ga (pictures of beautiful women) for which he is famous. Each double page of the book contains a painted illustration of a plant and two species of insects, along with two kyo\u0304ka (a poem style originating from waka, literally, Japanese poems). The kyo\u0304ka are ostensibly insect-themed love poems. In all, 15 colored wood-block prints are included. The work demonstrates Utamaro's skill at drawing, as well as the high-quality printing techniques of the day. The book was published by Tsutaya Juzaburo\u0304 (1750-97), a press mogul in the late Edo period (1600-1868).", "label": "The Insect Book.", "logo": "https://loc.gov/static/images/logo-loc-new-branding.svg", "metadata": [{"label": "APA Citation Style", "value": "Kitagawa, U. (1788) <cite>The Insect Book</cite>. Edo: Tsutaya Ju\u0302zaburo\u0302. [Pdf] Retrieved from the Library of Congress, https://www.loc.gov/item/2021666418/."}, {"label": "MLA Citation Style", "value": "Kitagawa, Utamaro, 1753?-1806 Artist. <cite>The Insect Book</cite>. Edo: Tsutaya Ju\u0302zaburo\u0302, 1788. Pdf. Retrieved from the Library of Congress, &lt;www.loc.gov/item/2021666418/&gt;."}, {"label": "Chicago Citation Style", "value": "Kitagawa, Utamaro, 1753?-1806 Artist. <cite>The Insect Book</cite>. Edo: Tsutaya Ju\u0302zaburo\u0302, 1788. Pdf. https://www.loc.gov/item/2021666418/."}, {"label": "Contributors", "value": ["Kitagawa, Utamaro, 1753?-1806 Artist."]}, {"label": "Created Published", "value": ["Edo : Tsutaya Ju\u0302zaburo\u0302, 1788."]}, {"label": "Original Format", "value": ["book"]}, {"label": "Subjects", "value": ["plants", "ukiyo-e", "block printing", "japan", "flowers", "insects", "poetry", "japanese poetry"]}, {"label": "Online Format", "value": ["compressed data", "pdf", "image"]}, {"label": "Item Url", "value": "https://www.loc.gov/item/2021666418/"}], "navDate": "1788-01-01T00:00:00Z", "seeAlso": [{"@id": "https://lccn.loc.gov/2021666418/marcxml", "format": "text/xml"}, {"@id": "https://lccn.loc.gov/2021666418/mods", "format": "text/xml"}, {"@id": "https://lccn.loc.gov/2021666418/dc", "format": "text/html"}], "sequences": [{"@type": "sc:Sequence", "canvases": [{"@id": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001", "@type": "sc:Canvas", "height": 3227, "images": [{"@id": "https://www.loc.gov/resource/gdcwdl.wdl_11832/seq-1/", "@type": "oa:Annotation", "motivation": "sc:painting", "on": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001", "resource": {"@id": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001/full/pct:100/0/default.jpg", "@type": "dctypes:Image", "format": "image/jpeg", "height": 3227, "service": {"@context": "http://iiif.io/api/image/2/context.json", "@id": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001", "profile": "http://iiif.io/api/image/2/level2.json"}, "width": 2268}}], "label": "Page 1", "metadata": [{"label": "Library of Congress Resource URL", "value": "https://www.loc.gov/resource/gdcwdl.wdl_11832/?sp=1"}], "related": "https://www.loc.gov/resource/gdcwdl.wdl_11832/?sp=1", "service": {"@context": "http://iiif.io/api/image/2/context.json", "@id": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001", "profile": "http://iiif.io/api/image/2/level2.json"}, "thumbnail": {"@id": "https://tile.loc.gov/image-services/iiif/service:gdc:gdcwdl:wd:l_:11:83:2:wdl_11832:1288345_R0000001/full/pct:12.5/0/default.jpg", "format": "image/jpeg", "height"